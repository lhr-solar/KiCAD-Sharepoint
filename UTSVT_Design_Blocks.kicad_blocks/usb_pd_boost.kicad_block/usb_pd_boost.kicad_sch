	(text "9V:\nIOUT_MAX = 9*(5.25-0.994/2)*0.9/24\nIOUT_MAX ≈ 1.60A (IC Limit)\nIOUT (90% efficient) = 1A\n\n20V:\nIOUT_MAX ≈ 3.62A (IC Limit)\nReal (90% efficient) = 2.25A\nIOUT = 54W / 24V\nIOUT ≈ 2.25A\n95% → 57W out → 24V @ 2.38A"
		(exclude_from_sim no)
		(at 81.534 182.626 0)
