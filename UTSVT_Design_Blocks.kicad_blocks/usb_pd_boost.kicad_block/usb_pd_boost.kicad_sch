	)
	(text "ΔIL = VIN × D / (L × fSW)\nΔIL = 9 × 0.6625 / (10µH × 600kHz)\nΔIL ≈ 0.994A\n\nICIN,rms = ΔIL / √12\nICIN,rms = 0.994 / 3.464\nICIN,rms ≈ 0.287A\n\nAllowing 50mV ripple\nCIN ≥ 0.994 / (4 × 600k × 0.05)\nCIN ≥ 8.3µF effective"
		(exclude_from_sim no)
