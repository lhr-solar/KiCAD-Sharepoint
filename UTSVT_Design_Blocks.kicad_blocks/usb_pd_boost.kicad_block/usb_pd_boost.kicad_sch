	(text "Vin = 9V\nDmax = 1 - (Vin*efficiency/Vout)\nDmax = 1 - ((9*0.9)/24)\nDmax = 0.6625\nVin = 20V\nD = 1 - (VIN × η / VOUT)\nD = 1 - (20 × 0.9 / 24)\nD = 1 - 0.75\nD = 0.25"
		(exclude_from_sim no)
		(at 236.728 124.46 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "079b3552-efdb-4de8-8eba-145d74cffb25")
	)
	(text "Dmax = 0.6625\nIOUT = 1A\nfSW = 600kHz\nCOUT_nominal = 3×4.7µF + 2×1µF = 16.1µF\nVripple = Dmax*Iout/fsw*Cout\nVripple ≈ 68.6 mV"
		(exclude_from_sim no)
		(at 210.566 149.352 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0b9dd44c-de69-4ae8-ad07-ee6ddf337cb3")
	)
