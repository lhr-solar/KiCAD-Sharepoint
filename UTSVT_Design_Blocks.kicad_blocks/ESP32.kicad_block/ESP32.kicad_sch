	)
	(text "Outside requirements: there must be an LDO and MUX design block\non your schematic. The +5V_LDO_IN should be routed to the power\ninput of the LDO design block. The output of that LDO, +3.3V_USB,\nshould then be wired to one of the inputs of the MUX\nthe other input to the MUX should be your main board +3.3V\nThe output from this MUX must be routed back to the ESP design\nblock as +3.3V_MUX_OUT input\n"
		(exclude_from_sim no)
		(at 17.78 34.798 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "5413ab6c-36f1-4a8c-ab0f-060b49785244")
	)
